# ─────────────────────────────────────────────────────────────
#  DevPulse — Environment Variables
#  Copy this file to .env in the project root (same folder as docker-compose.yml)
#  NEVER commit .env to GitHub — it's already in .gitignore
# ─────────────────────────────────────────────────────────────

# ── JWT Secret ───────────────────────────────────────────────
# Must be at least 32 characters. Use a random string.
# Generate one at: https://1password.com/password-generator/
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars_abc123xyz

# ── Admin credentials ─────────────────────────────────────────
# YOU log in with these. Other users register via the sign-up form.
ADMIN_EMAIL=admin@devpulse.com
ADMIN_PASSWORD=your_strong_password_here

# ── MongoDB ───────────────────────────────────────────────────
# Local Docker: leave as-is (docker-compose sets the container hostname)
# Production (MongoDB Atlas): replace with your Atlas connection string
MONGODB_URI=mongodb://mongo:27017/devpulse

# ── CORS ─────────────────────────────────────────────────────
# Local: keep as-is
# Production: replace with your actual GitHub Pages URL
CORS_ORIGINS=http://localhost:4200,http://localhost:4201

# ── Optional: Cloudinary image hosting ───────────────────────
# Free tier at https://cloudinary.com (25GB storage)
# Format: cloudinary://api_key:api_secret@cloud_name
# Leave blank to use base64 encoding (simpler, no account needed)
CLOUDINARY_URL=

# ── Token expiry (30 days in milliseconds) ───────────────────
JWT_EXPIRATION_MS=2592000000
